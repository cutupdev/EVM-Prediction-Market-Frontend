# --- On-chain ---
# Deployed PredictionMarket (or CTF adapter) contract — 0x-prefixed checksummed address
VITE_PREDICTION_MARKET_ADDRESS=

# Collateral ERC20 used by the market (e.g. USDC on your chain)
VITE_COLLATERAL_TOKEN_ADDRESS=

# WalletConnect Cloud project id (required by RainbowKit)
# https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: default chain id when wallet is disconnected (e.g. 11155111 Sepolia, 1 Mainnet)
VITE_DEFAULT_CHAIN_ID=11155111

# --- Backend (orderbook, indexing, signed orders) ---
# Absolute URL or leave empty to use Vite proxy: /api -> vite.config proxy target
VITE_API_BASE_URL=

# Optional: WebSocket URL for live orderbook / fills (if your backend exposes one)
VITE_API_WS_URL=
